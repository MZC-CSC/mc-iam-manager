@startuml

title "Create Workspace"

actor User as user

participant "app.go" as app
participant "workspaces.go" as controller
participant "workspacesHandler.go" as handler
participant "Database" as db

user    -> app : POST: /api/ws
app    -> controller : CreateWorkspace
controller -> handler : CreateWorkspace
handler -> db :
db -> handler :
handler -> controller :
controller -> app :
user <- app : return successMessage | json message

@enduml
