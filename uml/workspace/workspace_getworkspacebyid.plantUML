@startuml

title "GetWorkspaceById"

actor User as user

participant "app.go" as app
participant "workspaces.go" as controller
participant "workspacesHandler.go" as handler
participant "Database" as db

user    -> app : GET: /api/ws/workspace/id/{workspaceId}
app    -> controller : GetWorkspaceById
controller -> handler : GetWorkspaceById
handler -> db :
db -> handler :
handler -> controller :
controller -> app :
user <- app : return successMessage | json message (WorkspaceOne)

@enduml
