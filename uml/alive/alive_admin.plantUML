@startuml

title "Alive Admin"

actor User as user

participant "app.go" as app
participant "mcimw.go" as mcimw

user    -> app : GET: /alive/admin
app     -> mcimw: BuffaloMcimw(), mcimw.GrantedRoleList = []string{"admin"}
mcimw -> mcimw: BuffaloMiddleware()
mcimw -> app
app -> user: return successMessage | json

@enduml
